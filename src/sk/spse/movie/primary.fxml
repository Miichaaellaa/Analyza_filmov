<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox spacing="5">
            <padding>
                <Insets bottom="10" left="20" right="20" top="15" />
            </padding>

            <Label text="FILMOVÁ DATABÁZA">
            </Label>

            <Label text="0 načítaných filmov">
            </Label>
        </VBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <Tab text="Hľadať podľa názvu">
                <VBox spacing="15">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20" />
                    </padding>

                    <Label text="Vyhľadávanie filmov podľa názvu" />

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label minWidth="100" text="Názov filmu:" />
                        <TextField promptText="Batman" HBox.hgrow="ALWAYS" />
                        <Button text="Vyhľadať" />
                    </HBox>

                    <Separator />

                    <Label />
                    <TableView VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn prefWidth="400" text="Názov filmu">
                                <cellValueFactory><PropertyValueFactory property="title" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="80" text="Rok">
                                <cellValueFactory><PropertyValueFactory property="year" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="200" text="Žáner">
                                <cellValueFactory><PropertyValueFactory property="genresString" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="300" text="Herecké obsadenie">
                                <cellValueFactory><PropertyValueFactory property="castString" /></cellValueFactory>
                            </TableColumn>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Hľadať podľa žánru a roku">
                <VBox spacing="15">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20" />
                    </padding>

                    <Label text="Vyhľadávanie filmov podľa žánru a roku" />

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label minWidth="100" text="Žáner:" />
                        <ComboBox editable="true" promptText="Vyberte žáner" HBox.hgrow="ALWAYS" />
                        <Label minWidth="50" text="Rok:" />
                        <Spinner editable="true" minWidth="100" />
                        <Button text="Vyhľadať" />
                    </HBox>

                    <Separator />

                    <Label />
                    <TableView VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn prefWidth="400" text="Názov filmu">
                                <cellValueFactory><PropertyValueFactory property="title" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="80" text="Rok">
                                <cellValueFactory><PropertyValueFactory property="year" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="200" text="Žáner">
                                <cellValueFactory><PropertyValueFactory property="genresString" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="300" text="Herecké obsadenie">
                                <cellValueFactory><PropertyValueFactory property="castString" /></cellValueFactory>
                            </TableColumn>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Hľadať podľa herca">
                <VBox spacing="15">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20" />
                    </padding>

                    <Label text="Vyhľadávanie filmov podľa herca" />

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label minWidth="100" text="Meno herca:" />
                        <TextField promptText="Angelina Jolie" HBox.hgrow="ALWAYS" />
                        <Button text="Vyhľadať" />
                    </HBox>

                    <Separator />

                    <Label />
                    <TableView VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn prefWidth="400" text="Názov filmu">
                                <cellValueFactory><PropertyValueFactory property="title" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="80" text="Rok">
                                <cellValueFactory><PropertyValueFactory property="year" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="200" text="Žáner">
                                <cellValueFactory><PropertyValueFactory property="genresString" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="300" text="Herecké obsadenie">
                                <cellValueFactory><PropertyValueFactory property="castString" /></cellValueFactory>
                            </TableColumn>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <padding>
                <Insets bottom="5" left="15" right="15" top="5" />
            </padding>

            <Label />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>

</BorderPane>
