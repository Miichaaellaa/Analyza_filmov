<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sk.spse.movie.Controller">

    <stylesheets>
        <URL value="@dark.css" />
    </stylesheets>

    <top>
        <VBox spacing="5">
            <padding>
                <Insets bottom="10" left="20" right="20" top="15" />
            </padding>

            <Label text="FILMOVÁ DATABÁZA">
            </Label>

            <Label fx:id="movieCountLabel" text="Môže to chvíľu trvať, filmy sa načítavajú...">
            </Label>
        </VBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <Tab text="Hľadať podľa názvu">
                <VBox spacing="15">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20" />
                    </padding>

                    <Label text="Vyhľadávanie filmov podľa názvu" />

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label minWidth="100" text="Názov filmu:" />
                        <TextField fx:id="titleSearchField" promptText="Batman" HBox.hgrow="ALWAYS" />
                        <Button fx:id="searchTitleBtn" onAction="#searchByTitle" text="Vyhľadať" />
                    </HBox>

                    <Separator />

                    <Label fx:id="titleResultLabel" />
                    <TableView fx:id="titleTableView" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn prefWidth="400" text="Názov filmu">
                                <cellValueFactory><PropertyValueFactory property="title" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="80" text="Rok">
                                <cellValueFactory><PropertyValueFactory property="year" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="200" text="Žáner">
                                <cellValueFactory><PropertyValueFactory property="genresString" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="300" text="Herecké obsadenie">
                                <cellValueFactory><PropertyValueFactory property="castString" /></cellValueFactory>
                            </TableColumn>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Hľadať podľa žánru a roku">
                <VBox spacing="15">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20" />
                    </padding>

                    <Label text="Vyhľadávanie filmov podľa žánru a roku" />

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label minWidth="100" text="Žáner:" />
                        <ComboBox fx:id="genreComboBox" editable="true" promptText="Vyberte žáner" HBox.hgrow="ALWAYS" />
                        <Label minWidth="50" text="Rok:" />
                        <Spinner fx:id="yearSpinner" editable="true" minWidth="100" />
                        <Button fx:id="searchGenreYearBtn" onAction="#searchByGenreAndYear" text="Vyhľadať" />
                    </HBox>

                    <Separator />

                    <Label fx:id="genreYearResultLabel" />
                    <TableView fx:id="genreYearTableView" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn prefWidth="400" text="Názov filmu">
                                <cellValueFactory><PropertyValueFactory property="title" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="80" text="Rok">
                                <cellValueFactory><PropertyValueFactory property="year" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="200" text="Žáner">
                                <cellValueFactory><PropertyValueFactory property="genresString" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="300" text="Herecké obsadenie">
                                <cellValueFactory><PropertyValueFactory property="castString" /></cellValueFactory>
                            </TableColumn>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Hľadať podľa herca">
                <VBox spacing="15">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20" />
                    </padding>

                    <Label text="Vyhľadávanie filmov podľa herca" />

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label minWidth="100" text="Meno herca:" />
                        <TextField fx:id="actorSearchField" promptText="Angelina Jolie" HBox.hgrow="ALWAYS" />
                        <Button fx:id="searchActorBtn" onAction="#searchByActor" text="Vyhľadať" />
                    </HBox>

                    <Separator />

                    <Label fx:id="actorResultLabel" />
                    <TableView fx:id="actorTableView" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn prefWidth="400" text="Názov filmu">
                                <cellValueFactory><PropertyValueFactory property="title" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="80" text="Rok">
                                <cellValueFactory><PropertyValueFactory property="year" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="200" text="Žáner">
                                <cellValueFactory><PropertyValueFactory property="genresString" /></cellValueFactory>
                            </TableColumn>
                            <TableColumn prefWidth="300" text="Herecké obsadenie">
                                <cellValueFactory><PropertyValueFactory property="castString" /></cellValueFactory>
                            </TableColumn>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <padding>
                <Insets bottom="5" left="15" right="15" top="5" />
            </padding>

            <Label fx:id="statusLabel" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>

</BorderPane>